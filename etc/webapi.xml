<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/appconfig/config" method="GET">
        <service class="IDangerous\AppConfig\Api\AppConfigInterface" method="getConfig"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
    <route url="/V1/appconfig/groups" method="GET">
        <service class="IDangerous\AppConfig\Api\AppConfigInterface" method="getGroups"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/session/exchange" method="POST">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="exchangeSession"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/json" method="GET">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="getJson"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/url-routes" method="GET">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="listHeadlessUrlRoutes"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/json" method="POST">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="saveJson"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/register-url" method="POST">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="registerHeadlessUrl"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/unregister-url" method="POST">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="unregisterHeadlessUrl"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/appconfig/headless/delete-json-keys" method="POST">
        <service class="IDangerous\AppConfig\Api\HeadlessIntegrationInterface" method="deleteHeadlessJsonKeys"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

</routes>


