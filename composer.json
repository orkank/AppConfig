    "type": "magento2-module",
    "version": "2.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Orkan K.",
            "role": "Developer"
        }
    ],
    "keywords": [
        "magento2",
        "app-configuration",
        "mobile-app",
        "api",
        "graphql",
        "headless",
        "key-value-store"
    ],
    "require": {
        "php": "~7.4.0||~8.1.0||~8.2.0",
        "magento/framework": "*",
        "magento/module-backend": "*",
        "magento/module-store": "*",
        "magento/module-api": "*"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "IDangerous\\AppConfig\\": ""
        }
    }
}
